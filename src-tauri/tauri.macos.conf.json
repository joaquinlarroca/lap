      "infoplist/ja.lproj/*": "ja.lproj",
      "infoplist/ko.lproj/*": "ko.lproj",
      "infoplist/pt-BR.lproj/*": "pt-BR.lproj",
      "infoplist/pt-PT.lproj/*": "pt-PT.lproj",
      "infoplist/ru.lproj/*": "ru.lproj",
      "infoplist/zh-Hans.lproj/*": "zh-Hans.lproj",
      "infoplist/zh-Hant.lproj/*": "zh-Hant.lproj"
